{
  "name": "pledin-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:www":          "npm run dev --workspace=apps/www",
    "dev:plataforma":   "npm run dev --workspace=apps/plataforma",
    "dev:fp":           "npm run dev --workspace=apps/fp",
    "build:www":        "npm run build --workspace=apps/www",
    "build:plataforma": "npm run build --workspace=apps/plataforma",
    "build:fp":         "npm run build --workspace=apps/fp",
    "build:all":        "npm run build --workspaces --if-present"
  }
}
