---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import BlogSidebar from '../../components/BlogSidebar.astro';
import { getExcerpt } from '../../utils/excerpt.ts';
import { getPostDate } from '../../utils/date';
import { getReadingTime } from '../../utils/readingTime';


const allPosts = (await getCollection('blog'))
  .sort((a, b) => getPostDate(b).valueOf() - getPostDate(a).valueOf());

// Agrupar por año
const postsByYear = new Map<number, typeof allPosts>();
for (const post of allPosts) {
  const year = getPostDate(post).getFullYear();
  if (!postsByYear.has(year)) postsByYear.set(year, []);
  postsByYear.get(year)!.push(post);
}
const years = [...postsByYear.keys()].sort((a, b) => b - a);
---

<BlogLayout title="Blog">
  <BlogSidebar slot="sidebar" />
  
  <img src="/pledin/assets/logo_blog.png" alt="Pledin" class="blog-banner" />
 
  {years.map(year => (
    <section class="year-section" id={String(year)}>
      <h2 class="year-title">{year}</h2>
      <div class="post-list">
        {postsByYear.get(year)!.map(post => {
          const slug = post.data.slug ?? post.id;
          const url = `/pledin/${slug.replace(/^blog\//, '')}/`;
          const date = getPostDate(post);
          return (
            <article class="post-preview">
              {post.data.cover && (
                <a href={url}>
                  <img src={post.data.cover} alt={post.data.title} class="cover" />
                </a>
              )}
              <div class="post-content">
                <h3><a href={url}>{post.data.title}</a></h3>
                <div class="post-meta">
                  <span class="meta-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    <time datetime={post.data.date.toISOString()}>
                      {post.data.date.toLocaleDateString('es-ES', { dateStyle: 'long' })}
                    </time>
                  </span>
                  <span class="meta-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    <span>{getReadingTime(post.body ?? '')} min de lectura</span>
                  </span>
                </div>
                <p class="excerpt">{post.data.excerpt ?? getExcerpt(post.body ?? '')}</p>
                {post.data.tags && (
                  <div class="tags">
                    {post.data.tags.map(tag => (
                      <a href={`/pledin/tags/${tag.toLowerCase().replace(/ /g, '-')}/`} class="tag">
                        {tag}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>
    </section>
  ))}
</BlogLayout>

<style>
  .year-section {
    margin-bottom: 3rem;
  }

  .year-title {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-accent-high);
    border-bottom: 2px solid var(--color-border);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .post-preview {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2rem;
  }

  .cover {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 0.5rem;
    margin-bottom: 1rem;
  }

  .post-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  h3 {
    font-size: 1.3rem;
    font-weight: 700;
  }

  h3 a {
    color: var(--color-text);
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--color-accent-high);
  }

  time {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .excerpt {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }

  .tag {
    font-size: 0.75rem;
    background: var(--color-bg-sidebar);
    color: var(--color-text-muted);
    padding: 0.2rem 0.6rem;
    border-radius: 1rem;
    text-decoration: none;
    transition: background 0.2s;
  }

  .tag:hover {
    background: var(--color-accent);
    color: white;
    text-decoration: none;
  }
 .year-section {
  scroll-margin-top: calc(var(--nav-height) + 1rem);
}

.blog-banner {
  width: 100%;
  max-width: 400px;
  margin: 0 auto 2rem auto;
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.875rem;
  color: var(--color-text-muted);
}

</style>