---
import { getCollection } from 'astro:content';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import BlogSidebar from '../../../components/BlogSidebar.astro';
import { getExcerpt } from '../../../utils/excerpt.ts';
import { getPostDate } from '../../../utils/date';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  const tagMap = new Map<string, string>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      tagMap.set(tag.toLowerCase().replace(/ /g, '-'), tag);
    }
  }

  return [...tagMap.entries()].map(([slug, label]) => ({
    params: { tag: slug },
    props: { tag: slug, label },
  }));
}

const { tag, label } = Astro.props;
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => post.data.tags?.some(t => t.toLowerCase().replace(/ /g, '-') === tag))
  .sort((a, b) => getPostDate(b).valueOf() - getPostDate(a).valueOf());
---

<BlogLayout title={`Etiqueta: ${tag}`}>
  <BlogSidebar slot="sidebar" />

  <h1 class="tag-title">Etiqueta: <span>{tag}</span></h1>
  <p class="tag-count">{posts.length} entrada{posts.length !== 1 ? 's' : ''}</p>

  <div class="post-list">
    {posts.map(post => {
      const slug = post.data.slug ?? post.id;
      const url = `/pledin/${slug.replace(/^blog\//, '')}/`;
      const date = getPostDate(post);
      return (
        <article class="post-preview">
          <h2><a href={url}>{post.data.title}</a></h2>
          <time datetime={date.toISOString()}>
            {date.toLocaleDateString('es-ES', { dateStyle: 'long' })}
          </time>
          <p class="excerpt">{post.data.excerpt ?? getExcerpt(post.body ?? '')}</p>
        </article>
      );
    })}
  </div>
</BlogLayout>

<style>
  .tag-title {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .tag-title span {
    color: var(--color-accent);
  }

  .tag-count {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .post-preview {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  h2 {
    font-size: 1.2rem;
    font-weight: 700;
  }

  h2 a {
    color: var(--color-text);
    text-decoration: none;
  }

  h2 a:hover {
    color: var(--color-accent-high);
  }

  time {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .excerpt {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>