---
import { getCollection } from 'astro:content';
import BlogLayout from '../../../layouts/BlogLayout.astro';
import BlogSidebar from '../../../components/BlogSidebar.astro';
import PostMeta from '../../../components/PostMeta.astro';
import TagList from '../../../components/TagList.astro';
import { getExcerpt } from '../../../utils/excerpt.ts';
import { getPostDate } from '../../../utils/date';
import { getReadingTime } from '../../../utils/readingTime';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  const tagMap = new Map<string, string>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      tagMap.set(tag.toLowerCase().replace(/ /g, '-'), tag);
    }
  }

  return [...tagMap.entries()].map(([slug, label]) => ({
    params: { tag: slug },
    props: { tag: slug, label },
  }));
}

const { tag, label } = Astro.props;
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => post.data.tags?.some(t => t.toLowerCase().replace(/ /g, '-') === tag))
  .sort((a, b) => getPostDate(b).valueOf() - getPostDate(a).valueOf());
---

<BlogLayout title={`Etiqueta: ${label}`}>
  <BlogSidebar slot="sidebar" />

  <h1 class="tag-title">Etiqueta: <span>{label}</span></h1>
  <p class="tag-count">{posts.length} entrada{posts.length !== 1 ? 's' : ''}</p>

  <div class="post-list">
    {posts.map(post => {
      const slug = post.data.slug ?? post.id;
      const url = `/pledin/${slug.replace(/^blog\//, '')}/`;
      const date = getPostDate(post);
      return (
        <article class="post-preview">
          {post.data.cover && (
            <a href={url}>
              <img src={post.data.cover} alt={post.data.title} class="cover" />
            </a>
          )}
          <div class="post-content">
            <h2><a href={url}>{post.data.title}</a></h2>
            <PostMeta date={date} readingTime={getReadingTime(post.body ?? '')} />
            <p class="excerpt">{post.data.excerpt ?? getExcerpt(post.body ?? '')}</p>
            <TagList tags={post.data.tags ?? []} baseUrl="/pledin/tags/" />
          </div>
        </article>
      );
    })}
  </div>
</BlogLayout>

<style>
  .tag-title {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .tag-title span {
    color: var(--color-accent);
  }

  .tag-count {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .post-preview {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2rem;
  }

  .cover {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 0.5rem;
    margin-bottom: 1rem;
  }

  .post-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  h2 {
    font-size: 1.3rem;
    font-weight: 700;
  }

  h2 a {
    color: var(--color-text);
    text-decoration: none;
  }

  h2 a:hover {
    color: var(--color-accent-high);
  }

  .excerpt {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>