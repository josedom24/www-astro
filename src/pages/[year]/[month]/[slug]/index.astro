---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../../../layouts/BlogLayout.astro';
import BlogSidebar from '../../../../components/BlogSidebar.astro';
import { getPostDate } from '../../../../utils/date';
import Comments from '../../../../components/Comments.astro';
import Giscus from '../../../../components/Giscus.astro';


export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => {
    const parts = post.id.replace(/^blog\//, '').split('/');
    const year = parts[0];
    const month = parts[1];
    const slug = parts[2];
    return {
      params: { year, month, slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const date = getPostDate(post);

const allComments = import.meta.glob('/src/data/comments/*.json', { eager: true });
const postSlug = post.id.split('/').pop();
const comments = (allComments[`/src/data/comments/${postSlug}.json`] as any)?.default ?? [];
console.log('postSlug:', postSlug);
console.log('comments length:', comments.length);
console.log('available keys:', Object.keys(allComments).slice(0, 3));
---

<BlogLayout title={post.data.title} description={post.data.excerpt} headings={headings}>
  <BlogSidebar slot="sidebar" />

  <article class="post">
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <time datetime={date.toISOString()}>
        {date.toLocaleDateString('es-ES', { dateStyle: 'long' })}
      </time>
      {post.data.tags && (
        <div class="tags">
          {post.data.tags.map(tag => (
            <a href={`/pledin/tags/${tag.toLowerCase().replace(/ /g, '-')}/`} class="tag">
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    {post.data.cover && (
      <img src={post.data.cover} alt={post.data.title} class="cover" />
    )}

    <div class="post-body">
      <Content />
    </div>
  </article>
  <h2 class="giscus-title">Nuevos comentarios</h2>
  <Giscus />

  <Comments comments={comments} title="Comentarios antiguos" />
  
</BlogLayout>


<style>
  .post-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  h1 {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-text);
  }

  time {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.75rem;
    background: var(--color-bg-sidebar);
    color: var(--color-text-muted);
    padding: 0.2rem 0.6rem;
    border-radius: 1rem;
    text-decoration: none;
    transition: background 0.2s;
  }

  .tag:hover {
    background: var(--color-accent);
    color: white;
    text-decoration: none;
  }

  .cover {
    width: 100%;
    height: 300px;
    object-fit: cover;
    border-radius: 0.5rem;
    margin-bottom: 2rem;
  }

  .post-body {
    line-height: 1.8;
    font-size: 1rem;
  }

  .post-body :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 2rem 0 1rem;
  }

  .post-body :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 1.5rem 0 0.75rem;
  }

  .post-body :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 1rem 0 1.25rem 1.5rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .post-body :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: 1rem;
    color: var(--color-text-muted);
    margin: 1.5rem 0;
  }

  .post-body :global(img) {
    border-radius: 0.5rem;
    margin: 1.5rem auto;
  }

  .post-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .post-body :global(th),
  .post-body :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .post-body :global(th) {
    background: var(--color-bg-sidebar);
    font-weight: 700;
  }
  .post-body :global(h2),
.post-body :global(h3) {
  scroll-margin-top: calc(var(--nav-height) + 1rem);
}

  .giscus-title {
    font-size: 1.4rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-top: 2rem;
    border-top: 2px solid var(--color-border);
    color: var(--color-text);
  }

</style>