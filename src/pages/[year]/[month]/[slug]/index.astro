---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../../../layouts/BlogLayout.astro';
import BlogSidebar from '../../../../components/BlogSidebar.astro';
import PostMeta from '../../../../components/PostMeta.astro';
import TagList from '../../../../components/TagList.astro';
import { getPostDate } from '../../../../utils/date';
import Comments from '../../../../components/Comments.astro';
import Giscus from '../../../../components/Giscus.astro';
import { getReadingTime } from '../../../../utils/readingTime';


export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => {
    const parts = post.id.replace(/^blog\//, '').split('/');
    const year = parts[0];
    const month = parts[1];
    const slug = parts[2];
    return {
      params: { year, month, slug },
      props: { post },
    };
  });
}



const { post } = Astro.props;
const { Content, headings } = await render(post);
const date = getPostDate(post);

const allComments = import.meta.glob('/src/data/comments/*.json', { eager: true });
const postSlug = post.id.split('/').pop();
const comments = (allComments[`/src/data/comments/${postSlug}.json`] as any)?.default ?? [];

const readingTime = getReadingTime(post.body ?? '');

const allPosts = (await getCollection('blog'))
  .sort((a, b) => getPostDate(a).valueOf() - getPostDate(b).valueOf());

const currentIndex = allPosts.findIndex(p => p.id === post.id);
const prevPost = allPosts[currentIndex - 1];
const nextPost = allPosts[currentIndex + 1];

const getPostUrl = (p: typeof post) => {
  const slug = p.data.slug ?? p.id;
  return `/pledin/${slug.replace(/^blog\//, '')}/`;
};

const relatedPosts = allPosts
  .filter(p => p.id !== post.id)
  .filter(p => p.data.tags?.some(tag => post.data.tags?.includes(tag)))
  .sort((a, b) => {
    const aMatches = a.data.tags?.filter(tag => post.data.tags?.includes(tag)).length ?? 0;
    const bMatches = b.data.tags?.filter(tag => post.data.tags?.includes(tag)).length ?? 0;
    if (bMatches !== aMatches) return bMatches - aMatches;
    return getPostDate(b).valueOf() - getPostDate(a).valueOf();
  })
  .slice(0, 3);
---

<BlogLayout title={post.data.title} description={post.data.excerpt} headings={headings}>
  <BlogSidebar slot="sidebar" />

  <article class="post">
    <header class="post-header">
      <h1>{post.data.title}</h1>
      <PostMeta date={date} readingTime={readingTime} />
      <TagList tags={post.data.tags ?? []} baseUrl="/pledin/tags/" />
    </header>

    {post.data.cover && (
      <img src={post.data.cover} alt={post.data.title} class="cover" />
    )}

    <div class="post-body">
      <Content />
    </div>
  </article>

  <nav class="post-nav">
  {prevPost && (
    <a href={getPostUrl(prevPost)} class="post-nav-item prev">
      <span class="nav-label">← Anterior</span>
      <span class="nav-title">{prevPost.data.title}</span>
    </a>
  )}
  {nextPost && (
    <a href={getPostUrl(nextPost)} class="post-nav-item next">
      <span class="nav-label">Siguiente →</span>
      <span class="nav-title">{nextPost.data.title}</span>
    </a>
  )}
</nav>
{relatedPosts.length > 0 && (
  <section class="related-posts">
    <h2>Posts relacionados</h2>
    <div class="related-list">
      {relatedPosts.map(p => (
        <a href={getPostUrl(p)} class="related-item">
          <span class="related-title">{p.data.title}</span>
          <span class="related-date">
            {getPostDate(p).toLocaleDateString('es-ES', { dateStyle: 'long' })}
          </span>
        </a>
      ))}
    </div>
  </section>
)}

  <h2 class="giscus-title">Nuevos comentarios</h2>
  <Giscus />

  <Comments comments={comments} title="Comentarios antiguos" />
  
</BlogLayout>


<style>
  .post-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  h1 {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.2;
    color: var(--color-text);
  }

  time {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .cover {
    width: 100%;
    height: 300px;
    object-fit: cover;
    border-radius: 0.5rem;
    margin-bottom: 2rem;
  }

  .post-body {
    line-height: 1.8;
    font-size: 1rem;
  }

  .post-body :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 2rem 0 1rem;
  }

  .post-body :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 1.5rem 0 0.75rem;
  }

  .post-body :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 1rem 0 1.25rem 1.5rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .post-body :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: 1rem;
    color: var(--color-text-muted);
    margin: 1.5rem 0;
  }

  .post-body :global(img) {
    border-radius: 0.5rem;
    margin: 1.5rem auto;
  }

  .post-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .post-body :global(th),
  .post-body :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .post-body :global(th) {
    background: var(--color-bg-sidebar);
    font-weight: 700;
  }
  .post-body :global(h2),
.post-body :global(h3) {
  scroll-margin-top: calc(var(--nav-height) + 1rem);
}

  .giscus-title {
    font-size: 1.4rem;
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-top: 2rem;
    border-top: 2px solid var(--color-border);
    color: var(--color-text);
  }
  .post-nav {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
}

.post-nav-item {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  max-width: 45%;
  text-decoration: none;
  padding: 1rem;
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  background: var(--color-bg-nav);
  transition: border-color 0.2s;
}

.post-nav-item:hover {
  border-color: var(--color-accent);
  text-decoration: none;
}

.post-nav-item.next {
  margin-left: auto;
  text-align: right;
}

.nav-label {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  font-weight: 600;
}

.nav-title {
  font-size: 0.9rem;
  color: var(--color-text);
  font-weight: 600;
  line-height: 1.4;
}
.related-posts {
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid var(--color-border);
}

.related-posts h2 {
  font-size: 1.2rem;
  font-weight: 700;
  margin-bottom: 1rem;
  color: var(--color-text);
}

.related-list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.related-item {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  padding: 0.75rem 1rem;
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  background: var(--color-bg-nav);
  text-decoration: none;
  transition: border-color 0.2s;
}

.related-item:hover {
  border-color: var(--color-accent);
  text-decoration: none;
}

.related-title {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--color-text);
}

.related-date {
  font-size: 0.8rem;
  color: var(--color-text-muted);
}
</style>