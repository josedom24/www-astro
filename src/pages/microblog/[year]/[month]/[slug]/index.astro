---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../../../layouts/BaseLayout.astro';


export async function getStaticPaths() {
  const posts = await getCollection('microblog');
  return posts.map(post => {
    const match = post.id.match(/^(\d{4})-(\d{2})-\d{2}-(.+)$/);
    return {
      params: { 
        year: match![1], 
        month: match![2], 
        slug: match![3] 
      },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
const date = post.data.date;
---

<BaseLayout title={post.data.title}>
  <div class="microblog-wrapper">
    <a href="/pledin/microblog/" class="back">← Todos los posts</a>

    <article class="micropost">
      <header class="micropost-header">
        <div class="post-meta">
        <span class="meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('es-ES', { dateStyle: 'long' })}
          </time>
        </span>
      </div>
        {post.data.tags && (
          <div class="tags">
            {post.data.tags.map(tag => (
              <a href={`/pledin/microblog/tags/${tag.toLowerCase().replace(/ /g, '-')}/`} class="tag">
                {tag}
              </a>
            ))}
          </div>
        )}
      </header>

      <h1>{post.data.title}</h1>

      <div class="micropost-body">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .microblog-wrapper {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .back {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .back:hover { color: var(--color-accent); }

  .micropost {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 2rem;
    background: var(--color-bg-nav);
  }

  .micropost-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.75rem;
    background: var(--color-bg-sidebar);
    color: var(--color-text-muted);
    padding: 0.2rem 0.6rem;
    border-radius: 1rem;
    text-decoration: none;
    transition: background 0.2s;
  }

  .tag:hover {
    background: var(--color-accent);
    color: white;
    text-decoration: none;
  }

  h1 {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .micropost-body {
    line-height: 1.8;
    font-size: 1rem;
  }

  .micropost-body :global(p) { margin-bottom: 1.25rem; }

  .micropost-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
  }

  
  .post-meta {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  font-size: 0.875rem;
  color: var(--color-text-muted);
}
</style>
