---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('microblog');

  const tagMap = new Map<string, string>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      tagMap.set(tag.toLowerCase().replace(/ /g, '-'), tag);
    }
  }

  return [...tagMap.entries()].map(([slug, label]) => ({
    params: { tag: slug },
    props: { tag: slug, label },
  }));
}

const { tag, label } = Astro.props;
const allPosts = await getCollection('microblog');
const posts = allPosts
  .filter(post => post.data.tags?.some(t => t.toLowerCase().replace(/ /g, '-') === tag))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const renderedPosts = await Promise.all(
  posts.map(async post => {
    const { Content } = await render(post);
    return { post, Content };
  })
);
---

<BaseLayout title={`Microblog: ${label}`}>
  <div class="microblog-wrapper">
    <div class="microblog-header">
      <a href="/pledin/microblog/" class="back">← Todos los posts</a>
      <h1>#{label}</h1>
      <p class="count">{posts.length} entrada{posts.length !== 1 ? 's' : ''}</p>
    </div>

    <div class="posts">
      {renderedPosts.map(({ post, Content }) => {
        const date = post.data.date;
        const match = post.id.match(/^(\d{4})-(\d{2})-\d{2}-(.+)$/);
        const url = match
          ? `/pledin/microblog/${match[1]}/${match[2]}/${match[3]}/`
          : `/pledin/microblog/${post.id}/`;
        return (
          <article class="micropost">
            <div class="micropost-meta">
              <time datetime={date.toISOString()}>
                {date.toLocaleDateString('es-ES', { dateStyle: 'long' })}
              </time>
              {post.data.tags && (
                <div class="tags">
                  {post.data.tags.map(t => (
                    <a href={`/pledin/microblog/tags/${t.toLowerCase().replace(/ /g, '-')}/`} class="tag">
                      {t}
                    </a>
                  ))}
                </div>
              )}
            </div>
            <h2><a href={url}>{post.data.title}</a></h2>
            <div class="micropost-body">
              <Content />
            </div>
          </article>
        );
      })}
    </div>
  </div>
</BaseLayout>

<style>
  .microblog-wrapper {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .microblog-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--color-border);
  }

  .back {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 0.75rem;
  }

  .back:hover { color: var(--color-accent); }

  h1 {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .count {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .posts {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .micropost {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    background: var(--color-bg-nav);
    transition: border-color 0.2s;
  }

  .micropost:hover { border-color: var(--color-accent); }

  .micropost-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tag {
    font-size: 0.75rem;
    background: var(--color-bg-sidebar);
    color: var(--color-text-muted);
    padding: 0.2rem 0.6rem;
    border-radius: 1rem;
    text-decoration: none;
    transition: background 0.2s;
  }

  .tag:hover {
    background: var(--color-accent);
    color: white;
    text-decoration: none;
  }

  h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  h2 a {
    color: var(--color-text);
    text-decoration: none;
  }

  h2 a:hover { color: var(--color-accent-high); }

  .micropost-body {
    line-height: 1.8;
    font-size: 1rem;
    margin-top: 0.5rem;
  }

  .micropost-body :global(p) { margin-bottom: 1.25rem; }

  .micropost-body :global(ul),
  .micropost-body :global(ol) {
    margin: 1rem 0 1.25rem 1.5rem;
  }

  .micropost-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .micropost-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .micropost-body :global(blockquote) {
    border-left: 4px solid var(--color-accent);
    padding-left: 1rem;
    color: var(--color-text-muted);
    margin: 1.5rem 0;
  }
</style>