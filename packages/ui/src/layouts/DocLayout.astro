---
import BaseLayout from './BaseLayout.astro';
import DocSidebar from '../components/DocSidebar.astro';
import type { NavItem } from '../components/DocSidebar.astro';

export interface Props {
  title: string;
  courseTitle?: string;
  nav?: NavItem[];
  currentPath?: string;
  description?: string;
}

const {
  title,
  courseTitle,
  nav = [],
  currentPath = Astro.url.pathname,
  description,
} = Astro.props;
---

<BaseLayout {title} {description}>
  <div class="doc-wrapper">
    {nav.length > 0 && (
      <aside class="doc-sidebar">
        {courseTitle && <p class="course-label">{courseTitle}</p>}
        <DocSidebar nav={nav} currentPath={currentPath} />
      </aside>
    )}
    <main class="doc-main">
      <article class="doc-prose">
        <slot />
      </article>
    </main>
  </div>
</BaseLayout>

<style>
  .doc-wrapper {
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr;
    max-width: calc(var(--sidebar-width) + var(--content-width) + 4rem);
    margin: 0 auto;
    min-height: calc(100vh - var(--nav-height));
  }

  .doc-sidebar {
    border-right: 1px solid var(--color-border);
    background: var(--color-bg-sidebar);
    position: sticky;
    top: var(--nav-height);
    height: calc(100vh - var(--nav-height));
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 1.5rem 0.75rem;
  }

  .course-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    padding: 0 0.5rem 0.75rem;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .doc-main {
    min-width: 0;
    padding: 2rem 2.5rem;
  }

  .doc-prose {
    max-width: var(--content-width);
    line-height: 1.75;
  }

  .doc-prose :global(h1) {
    font-size: 1.875rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 1.5rem;
  }

  .doc-prose :global(h2) {
    font-size: 1.375rem;
    font-weight: 700;
    margin: 2.5rem 0 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .doc-prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 2rem 0 0.5rem;
  }

  .doc-prose :global(p)  { margin: 0 0 1rem; }

  .doc-prose :global(ul),
  .doc-prose :global(ol) { margin: 0 0 1rem; padding-left: 1.5rem; }

  .doc-prose :global(li) { margin-bottom: 0.35rem; }

  .doc-prose :global(pre) { margin: 1.25rem 0; }

  .doc-prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    margin: 1.25rem 0;
    padding: 0.75rem 1rem;
    background: var(--color-bg-sidebar);
    border-radius: 0 0.375rem 0.375rem 0;
    color: var(--color-text-muted);
  }

  .doc-prose :global(img) {
    border-radius: 0.375rem;
    border: 1px solid var(--color-border);
  }

  .doc-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.9rem;
  }

  .doc-prose :global(th),
  .doc-prose :global(td) {
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .doc-prose :global(th) {
    background: var(--color-bg-sidebar);
    font-weight: 600;
  }

  @media (max-width: 50rem) {
    .doc-wrapper { grid-template-columns: 1fr; }
    .doc-sidebar { display: none; }
    .doc-main { padding: 1.25rem 1rem; }
  }
</style>