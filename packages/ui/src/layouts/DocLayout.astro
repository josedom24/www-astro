---
import BaseLayout from '@pledin/ui/layouts/BaseLayout.astro';
import DocSidebar from '../components/DocSidebar.astro';
import type { NavItem } from '../components/DocSidebar.astro';

export interface Props {
  title: string;
  courseTitle?: string;
  nav?: NavItem[];
  currentPath?: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
  breadcrumb?: { title: string; url: string | null }[];
}

const {
  title,
  courseTitle,
  nav = [],
  currentPath = Astro.url.pathname,
  description,
  headings = [],
  breadcrumb = [],
} = Astro.props;

const toc = headings.filter(h => h.depth <= 3);

---

<BaseLayout {title} {description}>
  <div class:list={['doc-wrapper', { 'with-toc': toc.length > 0 }]}>
    {nav.length > 0 && (
      <aside class="doc-sidebar">
        <DocSidebar nav={nav} currentPath={currentPath} />
      </aside>
    )}
    <main class="doc-main">
      
      {breadcrumb && breadcrumb.length > 0 && (
        <nav class="breadcrumb" aria-label="Breadcrumb">
          {breadcrumb.map((item, i) => (
            <>
              {i > 0 && <span class="breadcrumb-sep">›</span>}
              {item.url
                ? <a href={item.url}>{item.title}</a>
                : <span class="breadcrumb-current">{item.title}</span>
              }
            </>
          ))}
        </nav>
      )}
      <article class="doc-prose">
        <slot />
      </article>
    </main>
    {toc.length > 0 && (
      <aside class="doc-toc">
        <div class="toc-inner">
          <p class="toc-title">En esta página</p>
          <li class="depth-1">
              <a href="#">{title}</a>
            </li>
          <ul>
            {toc.map(h => (
              <li class:list={[`depth-${h.depth}`]}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    )}
  </div>
</BaseLayout>
<style>
html {
  scroll-padding-top: var(--nav-height);
}
   .doc-prose :global(h1),
  .doc-prose :global(h2),
  .doc-prose :global(h3) {
    scroll-margin-top: calc(var(--nav-height) + 1rem);
  }
  .doc-wrapper {
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr;
    max-width: calc(var(--sidebar-width) + var(--content-width) + 4rem);
    margin: 0 auto;
    min-height: calc(100vh - var(--nav-height));
  }

  .doc-wrapper.with-toc {
    grid-template-columns: var(--sidebar-width) 1fr 14rem;
    max-width: calc(var(--sidebar-width) + var(--content-width) + 14rem + 4rem);
  }

  .doc-sidebar {
    border-right: 1px solid var(--color-border);
    background: var(--color-bg-sidebar);
    position: sticky;
    top: var(--nav-height);
    height: calc(100vh - var(--nav-height));
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 1.5rem 0.75rem;
  }

  .course-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    padding: 0 0.5rem 0.75rem;
    margin-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .doc-main {
    min-width: 0;
    padding: 2rem 2.5rem;
  }

  .doc-prose {
    max-width: var(--content-width);
    line-height: 1.75;
  }

  .doc-prose :global(h1) {
    font-size: 1.875rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 1.5rem;
  }

  .doc-prose :global(h2) {
    font-size: 1.375rem;
    font-weight: 700;
    margin: 2.5rem 0 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .doc-prose :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 2rem 0 0.5rem;
  }

  .doc-prose :global(p)  { margin: 0 0 1rem; }

  .doc-prose :global(ul),
  .doc-prose :global(ol) { margin: 0 0 1rem; padding-left: 1.5rem; }

  .doc-prose :global(li) { margin-bottom: 0.35rem; }

  .doc-prose :global(pre) { margin: 1.25rem 0; }

  .doc-prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    margin: 1.25rem 0;
    padding: 0.75rem 1rem;
    background: var(--color-bg-sidebar);
    border-radius: 0 0.375rem 0.375rem 0;
    color: var(--color-text-muted);
  }

  .doc-prose :global(img) {
    border-radius: 0.375rem;
    
  }

  .doc-prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.9rem;
  }

  .doc-prose :global(th),
  .doc-prose :global(td) {
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .doc-prose :global(th) {
    background: var(--color-bg-sidebar);
    font-weight: 600;
  }

  /* TOC */
  .doc-toc {
    position: sticky;
    top: calc(var(--nav-height) + 1rem);
    align-self: start;
    padding: 1.5rem 0.75rem;
  }

  .toc-inner {
    border-left: 2px solid var(--color-border);
    padding-left: 1rem;
  }

  .toc-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .doc-toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .doc-toc li {
    list-style: none;
  }
  .doc-toc li a {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    line-height: 1.4;
    display: block;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    border-left: 2px solid transparent;
    margin-left: -1.1rem;
    transition: all 0.2s;
  }

  .doc-toc li a:hover {
    color: var(--color-accent);
    background: var(--color-bg-sidebar);
    border-left-color: var(--color-accent);
  }

  .doc-toc li.depth-1 a {
    font-weight: 700;
    color: var(--color-text);
    font-size: 0.85rem;
  }

  .doc-toc li.depth-2 { padding-left: 0.75rem; }
  .doc-toc li.depth-3 { padding-left: 1.75rem; }

  /* Responsive */
  @media (max-width: 70rem) {
    .doc-wrapper.with-toc {
      grid-template-columns: var(--sidebar-width) 1fr;
    }
    .doc-toc { display: none; }
  }

  @media (max-width: 50rem) {
    .doc-wrapper { grid-template-columns: 1fr; }
    .doc-sidebar { display: none; }
    .doc-main { padding: 1.25rem 1rem; }
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .breadcrumb-sep {
    opacity: 0.4;
  }

  .breadcrumb-current {
    color: var(--color-text);
    font-weight: 500;
  }
  .doc-prose :global(blockquote) {
    margin: 1.25rem 0;
    padding: 0.75rem 1rem;
    border-radius: 0 0.375rem 0.375rem 0;
    border-left: 4px solid var(--color-border);
    background: var(--color-bg-sidebar);
    color: var(--color-text-muted);
  }

  
</style>