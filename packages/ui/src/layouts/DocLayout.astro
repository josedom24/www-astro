---
import type { NavItem } from '../components/DocSidebar.astro';
import DocSidebar from '../components/DocSidebar.astro';

export interface Props {
  title: string;
  courseTitle?: string;
  nav?: NavItem[];
  currentPath?: string;
  description?: string;
}

const { title, courseTitle, nav = [], currentPath = Astro.url.pathname, description } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}{courseTitle ? ` | ${courseTitle}` : ' | PLEDIN 3.0'}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/favicon.ico" />
    <style>
      *, *::before, *::after { box-sizing: border-box; }

      :root {
        --color-accent: #2563eb;
        --color-accent-light: #93c5fd;
        --color-active-bg: #eff6ff;
        --color-hover-bg: #f3f4f6;
        --color-text: #111827;
        --color-text-muted: #6b7280;
        --color-border: #e5e7eb;
        --color-bg: #ffffff;
        --color-surface: #f9fafb;
        --sidebar-width: 260px;
        --header-height: 56px;
        --font-body: 'Segoe UI', system-ui, sans-serif;
        --font-mono: 'Fira Code', 'Cascadia Code', monospace;
        --card-bg: #fff;
        --card-border: #e5e7eb;
        --tag-bg: #eff6ff;
      }

      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        font-family: var(--font-body);
        color: var(--color-text);
        background: var(--color-bg);
        font-size: 16px;
        line-height: 1.6;
      }

      /* HEADER */
      .doc-header {
        position: sticky;
        top: 0;
        z-index: 100;
        height: var(--header-height);
        background: var(--color-bg);
        border-bottom: 1px solid var(--color-border);
        display: flex;
        align-items: center;
        padding: 0 1rem;
        gap: 1rem;
      }

      .doc-header-brand {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: var(--color-text);
        font-weight: 700;
        font-size: 1.05rem;
        flex-shrink: 0;
      }

      .doc-header-brand span {
        color: var(--color-accent);
      }

      .doc-header-course {
        font-size: 0.875rem;
        color: var(--color-text-muted);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .doc-header-course::before {
        content: '/';
        margin-right: 0.5rem;
        opacity: 0.4;
      }

      .doc-header-nav {
        margin-left: auto;
        display: flex;
        gap: 1.25rem;
      }

      .doc-header-nav a {
        font-size: 0.875rem;
        color: var(--color-text-muted);
        text-decoration: none;
        transition: color 0.15s;
      }

      .doc-header-nav a:hover { color: var(--color-accent); }

      /* LAYOUT */
      .doc-layout {
        display: flex;
        min-height: calc(100vh - var(--header-height));
      }

      /* SIDEBAR */
      .doc-sidebar-wrap {
        width: var(--sidebar-width);
        flex-shrink: 0;
        border-right: 1px solid var(--color-border);
        background: var(--color-surface);
        position: sticky;
        top: var(--header-height);
        height: calc(100vh - var(--header-height));
        overflow-y: auto;
        overscroll-behavior: contain;
        padding: 1.25rem 0.75rem;
      }

      /* MAIN */
      .doc-main {
        flex: 1;
        min-width: 0;
        padding: 2rem 2.5rem;
        max-width: 860px;
      }

      /* BREADCRUMB */
      .doc-breadcrumb {
        font-size: 0.8rem;
        color: var(--color-text-muted);
        margin-bottom: 1.5rem;
        display: flex;
        gap: 0.5rem;
        align-items: center;
      }

      .doc-breadcrumb a {
        color: var(--color-text-muted);
        text-decoration: none;
      }

      .doc-breadcrumb a:hover { color: var(--color-accent); }
      .doc-breadcrumb .sep { opacity: 0.4; }

      /* PROSE */
      .doc-prose {
        line-height: 1.75;
      }

      .doc-prose h1 {
        font-size: 1.875rem;
        font-weight: 700;
        line-height: 1.2;
        margin: 0 0 1.5rem;
        color: var(--color-text);
      }

      .doc-prose h2 {
        font-size: 1.375rem;
        font-weight: 700;
        margin: 2.5rem 0 0.75rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid var(--color-border);
      }

      .doc-prose h3 {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 2rem 0 0.5rem;
      }

      .doc-prose p { margin: 0 0 1rem; }

      .doc-prose a {
        color: var(--color-accent);
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .doc-prose ul, .doc-prose ol {
        margin: 0 0 1rem;
        padding-left: 1.5rem;
      }

      .doc-prose li { margin-bottom: 0.35rem; }

      .doc-prose code {
        font-family: var(--font-mono);
        font-size: 0.875em;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 0.25rem;
        padding: 0.1em 0.35em;
      }

      .doc-prose pre {
        background: #1e1e2e;
        color: #cdd6f4;
        border-radius: 0.5rem;
        padding: 1.25rem;
        overflow-x: auto;
        margin: 1.25rem 0;
        font-family: var(--font-mono);
        font-size: 0.875rem;
        line-height: 1.6;
      }

      .doc-prose pre code {
        background: none;
        border: none;
        padding: 0;
        font-size: inherit;
        color: inherit;
      }

      .doc-prose blockquote {
        border-left: 3px solid var(--color-accent);
        margin: 1.25rem 0;
        padding: 0.75rem 1rem;
        background: var(--color-active-bg);
        border-radius: 0 0.375rem 0.375rem 0;
        color: var(--color-text-muted);
      }

      .doc-prose img {
        max-width: 100%;
        border-radius: 0.375rem;
        border: 1px solid var(--color-border);
      }

      .doc-prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.25rem 0;
        font-size: 0.9rem;
      }

      .doc-prose th, .doc-prose td {
        padding: 0.6rem 0.9rem;
        border: 1px solid var(--color-border);
        text-align: left;
      }

      .doc-prose th {
        background: var(--color-surface);
        font-weight: 600;
      }

      .doc-prose tr:nth-child(even) td {
        background: var(--color-surface);
      }

      /* Sidebar toggle mobile */
      .sidebar-toggle {
        display: none;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.4rem;
        color: var(--color-text);
      }

      @media (max-width: 768px) {
        .sidebar-toggle { display: flex; }

        .doc-sidebar-wrap {
          position: fixed;
          left: -100%;
          top: var(--header-height);
          height: calc(100vh - var(--header-height));
          z-index: 90;
          transition: left 0.25s;
          box-shadow: 4px 0 16px rgba(0,0,0,0.1);
        }

        .doc-sidebar-wrap.open {
          left: 0;
        }

        .doc-main {
          padding: 1.25rem 1rem;
        }

        .doc-header-course { display: none; }
      }
    </style>
  </head>
  <body>
    <header class="doc-header">
      <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Menú">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
      <a href="/pledin/" class="doc-header-brand">
        PLEDIN <span>3.0</span>
      </a>
      {courseTitle && <span class="doc-header-course">{courseTitle}</span>}
      <nav class="doc-header-nav">
        <a href="https://www.josedomingo.org/pledin/">Blog</a>
        <a href="/pledin/">Cursos</a>
        <a href="https://fp.josedomingo.org">FP</a>
      </nav>
    </header>

    <div class="doc-layout">
      {nav.length > 0 && (
        <aside class="doc-sidebar-wrap" id="sidebar">
          <DocSidebar nav={nav} currentPath={currentPath} />
        </aside>
      )}

      <main class="doc-main">
        <article class="doc-prose">
          <slot />
        </article>
      </main>
    </div>

    <script>
      const toggle = document.getElementById('sidebar-toggle');
      const sidebar = document.getElementById('sidebar');
      if (toggle && sidebar) {
        toggle.addEventListener('click', () => {
          sidebar.classList.toggle('open');
        });
        document.addEventListener('click', (e) => {
          if (!sidebar.contains(e.target as Node) && e.target !== toggle) {
            sidebar.classList.remove('open');
          }
        });
      }
    </script>
  </body>
</html>
