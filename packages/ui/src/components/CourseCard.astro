---
export interface Props {
  title: string;
  url: string;
  description?: string;
  year?: string | number;
  tags?: string[];
  external?: boolean;
}

const { title, url, description, year, tags = [], external = false } = Astro.props;

// Detectar si es enlace externo
const isExternal = external || url.startsWith('http');
const attrs = isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a href={url} class="course-card" {...attrs}>
  <div class="course-card-body">
    <h3 class="course-card-title">{title}</h3>
    {description && <p class="course-card-desc">{description}</p>}
    <div class="course-card-footer">
      {year && <span class="course-year">{year}</span>}
      {tags.map(tag => <span class="course-tag">{tag}</span>)}
      {isExternal && <span class="course-ext" title="Enlace externo">↗</span>}
    </div>
  </div>
</a>

<style>
  .course-card {
    display: flex;
    flex-direction: column;
    background: var(--card-bg, #fff);
    border: 1px solid var(--card-border, #e5e7eb);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.15s;
    overflow: hidden;
  }

  .course-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.10);
    border-color: var(--color-accent, #2563eb);
    transform: translateY(-2px);
  }

  .course-card-body {
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .course-card-title {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text, #111827);
    margin: 0;
  }

  .course-card:hover .course-card-title {
    color: var(--color-accent, #2563eb);
  }

  .course-card-desc {
    font-size: 0.825rem;
    color: var(--color-text-muted, #6b7280);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .course-card-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: center;
    margin-top: auto;
    padding-top: 0.4rem;
  }

  .course-year {
    font-size: 0.75rem;
    color: var(--color-text-muted, #9ca3af);
    font-variant-numeric: tabular-nums;
  }

  .course-tag {
    font-size: 0.7rem;
    background: var(--tag-bg, #eff6ff);
    color: var(--color-accent, #2563eb);
    border-radius: 999px;
    padding: 0.1em 0.6em;
    font-weight: 500;
  }

  .course-ext {
    margin-left: auto;
    font-size: 0.8rem;
    color: var(--color-text-muted, #9ca3af);
  }
</style>
