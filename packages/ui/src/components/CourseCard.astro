---
export interface Props {
  title: string;
  url: string;
  description?: string;
  year?: string | number;
  external?: 'none' | 'github' | 'web';
  ow?: boolean;
}

const { title, url, description, year, external = 'none', ow = false } = Astro.props;

const isExternal = external !== 'none';
const attrs = isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a href={url} class="course-card" {...attrs}>
  <div class="course-card-body">
    <h3 class="course-card-title">{title}</h3>
    {description && <p class="course-card-desc">{description}</p>}
    <div class="course-card-footer">
      {year && <span class="course-year">{year}</span>}
      {ow && <span class="badge-ow">OpenWebinars</span>}
      <span class="course-ext-icon">
        {external === 'github' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-label="GitHub">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        )}
        {external === 'web' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-label="Enlace externo">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        )}
      </span>
    </div>
  </div>
</a>

<style>
  .course-card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg, #fff);
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.15s;
    overflow: hidden;
  }

  .course-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    border-color: var(--color-accent, #3b82f6);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .course-card-body {
    padding: 0.875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }

  .course-card-title {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-accent, #3b82f6);
    margin: 0;
  }

  .course-card:hover .course-card-title {
    color: var(--color-accent-high, #1d4ed8);
  }

  .course-card-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted, #64748b);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .course-card-footer {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 0.35rem;
    flex-wrap: wrap;
  }

  .course-year {
    font-size: 0.72rem;
    color: var(--color-text-muted, #94a3b8);
    font-variant-numeric: tabular-nums;
  }

  .badge-ow {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--color-text-muted, #94a3b8);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .course-ext-icon {
    margin-left: auto;
    color: var(--color-text-muted, #94a3b8);
    display: flex;
    align-items: center;
  }
</style>