---
import PostMeta from './PostMeta.astro';
import TagList from './TagList.astro';

interface Props {
  url: string;
  title: string;
  date: Date;
  readingTime?: number;
  cover?: string;
  tags?: string[];
  tagsBaseUrl?: string;
  excerpt?: string;      // texto plano: blog/index y tags/[tag]
  previewHtml?: string;  // HTML renderizado: portada (<!--more-->)
  hasMore?: boolean;     // muestra "Seguir leyendo →"
}

const {
  url, title, date, readingTime,
  cover, tags = [], tagsBaseUrl = '/pledin/tags/',
  excerpt, previewHtml, hasMore = false,
} = Astro.props;
---

<article class="post-card">
  {cover && (
    <a href={url}>
      <img src={cover} alt={title} class="cover" />
    </a>
  )}
  <div class="post-content">
    <h2><a href={url}>{title}</a></h2>
    <PostMeta date={date} readingTime={readingTime} />
    {previewHtml
      ? <div class="post-body" set:html={previewHtml} />
      : excerpt && <p class="excerpt">{excerpt}</p>
    }
    {hasMore && <a href={url} class="detail-link">Seguir leyendo →</a>}
    {tags.length > 0 && <TagList tags={tags} baseUrl={tagsBaseUrl} />}
  </div>
</article>

<style>
  .post-card {
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    background: var(--color-bg-nav);
    transition: border-color 0.2s;
  }

  .post-card:hover {
    border-color: var(--color-accent);
  }

  .cover {
    display: block;
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 0.5rem;
    margin-bottom: 1rem;
  }

  .post-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  h2 {
    font-size: 1.3rem;
    font-weight: 700;
  }

  h2 a {
    color: var(--color-text);
    text-decoration: none;
  }

  h2 a:hover {
    color: var(--color-accent-high);
  }

  .excerpt {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* Preview HTML (portada) */
  .post-body {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .post-body :global(p)         { margin-bottom: 0.75rem; }
  .post-body :global(ul),
  .post-body :global(ol)        { margin: 0.5rem 0 0.75rem 1.5rem; padding-left: 1rem; }
  .post-body :global(li)        { margin-bottom: 0.3rem; padding-left: 0.25rem; }
  .post-body :global(img)       { border-radius: 0.5rem; margin: 1rem auto; }
  .post-body :global(a)         { color: var(--color-accent); text-decoration: underline; }
  .post-body :global(code)      { font-family: var(--font-mono); font-size: 0.875em; }
  .post-body :global(pre)       { border-radius: 0.5rem; overflow-x: auto; margin: 1rem 0; }

  .detail-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    display: inline-block;
  }

  .detail-link:hover { color: var(--color-accent-high); }
</style>
