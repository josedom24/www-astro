---
import { getPostDate } from '../utils/date';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
  getUrl: (post: CollectionEntry<'blog'>) => string;
}

const { posts, getUrl } = Astro.props;
---

{posts.length > 0 && (
  <section class="related-posts">
    <h2>Posts relacionados</h2>
    <div class="related-list">
      {posts.map(p => (
        <a href={getUrl(p)} class="related-item">
          <span class="related-title">{p.data.title}</span>
          <span class="related-date">
            {getPostDate(p).toLocaleDateString('es-ES', { dateStyle: 'long' })}
          </span>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related-posts {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .related-posts h2 {
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .related-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .related-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-bg-nav);
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .related-item:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .related-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .related-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
</style>
