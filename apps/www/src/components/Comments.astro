---
import { marked } from 'marked';

interface Comment {
  name: string;
  date: string;
  message: string;
  url?: string;
  email?: string;
}

interface Props {
  comments: Comment[];
}

interface Props {
  comments: Comment[];
  title?: string;
}

const { comments, title = 'Comentarios' } = Astro.props;
const parsedComments = comments.map(c => ({
  ...c,
  message: marked(c.message ?? '') as string
}));
---

{comments && comments.length > 0 && (
  <section class="comments">
    <h2>{title} ({comments.length})</h2>
    <div class="comment-list">
      {parsedComments.map(comment => (
        <article class="comment">
          <div class="comment-header">
            <div class="avatar">
              {comment.email
                ? <img src={`https://www.gravatar.com/avatar/${comment.email}?s=40&d=identicon`} alt={comment.name} width="40" height="40" />
                : (comment.name?.charAt(0).toUpperCase() ?? '?')
              }
            </div>
            <div class="comment-meta">
              <span class="comment-name">
                {comment.url ? <a href={comment.url}>{comment.name}</a> : comment.name}
              </span>
              <time>{new Date(comment.date).toLocaleDateString('es-ES', { dateStyle: 'long' })}</time>
            </div>
          </div>
          <div class="comment-body" set:html={(comment.message ?? '').replace(/\n/g, '<br/>')} />
        </article>
      ))}
    </div>
  </section>
)}

<style>
  .comments {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 2px solid var(--color-border);
  }

  h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 2rem;
    color: var(--color-text);
  }

  .comment-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .comment {
    padding: 1.25rem;
    background: var(--color-bg-nav);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
  }

  .comment-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--color-accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .comment-meta {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .comment-name {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .comment-name a {
    color: var(--color-accent);
    text-decoration: none;
  }

  time {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .comment-body {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .comment-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
  }
  .avatar img {
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 50%;
  display: block;
}
</style>