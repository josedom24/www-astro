---
interface Props {
  prevUrl?: string;
  prevTitle?: string;
  nextUrl?: string;
  nextTitle?: string;
}

const { prevUrl, prevTitle, nextUrl, nextTitle } = Astro.props;
---

{(prevUrl || nextUrl) && (
  <nav class="post-nav">
    {prevUrl && (
      <a href={prevUrl} class="post-nav-item prev">
        <span class="nav-label">← Anterior</span>
        <span class="nav-title">{prevTitle}</span>
      </a>
    )}
    {nextUrl && (
      <a href={nextUrl} class="post-nav-item next">
        <span class="nav-label">Siguiente →</span>
        <span class="nav-title">{nextTitle}</span>
      </a>
    )}
  </nav>
)}

<style>
  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .post-nav-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    max-width: 45%;
    text-decoration: none;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-bg-nav);
    transition: border-color 0.2s;
  }

  .post-nav-item:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .post-nav-item.next {
    margin-left: auto;
    text-align: right;
  }

  .nav-label {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .nav-title {
    font-size: 0.9rem;
    color: var(--color-text);
    font-weight: 600;
    line-height: 1.4;
  }
</style>
