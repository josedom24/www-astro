---
import { getCollection } from 'astro:content';
import BlogLayout from '@pledin/ui/layouts/BlogLayout.astro';
import BlogSidebar from '@pledin/ui/components/BlogSidebar.astro';
import PostCard from '@pledin/ui/components/PostCard.astro';
import { getExcerpt } from '@pledin/ui/utils/excerpt.ts';
import { getPostDate } from '@pledin/ui/utils/date';
import { getReadingTime } from '@pledin/ui/utils/readingTime';


const allPosts = (await getCollection('blog'))
  .sort((a, b) => getPostDate(b).valueOf() - getPostDate(a).valueOf());

// Agrupar por año
const postsByYear = new Map<number, typeof allPosts>();
for (const post of allPosts) {
  const year = getPostDate(post).getFullYear();
  if (!postsByYear.has(year)) postsByYear.set(year, []);
  postsByYear.get(year)!.push(post);
}
const years = [...postsByYear.keys()].sort((a, b) => b - a);
---

<BlogLayout title="Blog">
  <BlogSidebar slot="sidebar" />
  
  <img src="/pledin/assets/logo_blog.png" alt="Pledin" class="blog-banner" />
 
  {years.map(year => (
    <section class="year-section" id={String(year)}>
      <h2 class="year-title">{year}</h2>
      <div class="post-list">
        {postsByYear.get(year)!.map(post => {
          const slug = post.data.slug ?? post.id;
          const url = `/pledin/${slug.replace(/^blog\//, '')}/`;
          const date = getPostDate(post);
          return (
            <PostCard
              url={url}
              title={post.data.title}
              date={date}
              readingTime={getReadingTime(post.body ?? '')}
              cover={post.data.cover}
              tags={post.data.tags ?? []}
              excerpt={post.data.excerpt ?? getExcerpt(post.body ?? '')}
            />
          );
        })}
      </div>
    </section>
  ))}
</BlogLayout>

<style>
  .year-section {
    margin-bottom: 3rem;
    scroll-margin-top: calc(var(--nav-height) + 1rem);
  }

  .year-title {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-accent-high);
    border-bottom: 2px solid var(--color-border);
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .blog-banner {
    width: 100%;
    max-width: 400px;
    margin: 0 auto 2rem auto;
  }
</style>