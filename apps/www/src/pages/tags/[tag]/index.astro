---
import { getCollection } from 'astro:content';
import BlogLayout from '@pledin/ui/layouts/BlogLayout.astro';
import BlogSidebar from '../../../components/BlogSidebar.astro';
import PostCard from '../../../components/PostCard.astro';
import { getExcerpt } from '../../../utils/excerpt.ts';
import { getPostDate } from '../../../utils/date';
import { getReadingTime } from '../../../utils/readingTime';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tagMap = new Map<string, string>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      tagMap.set(tag.toLowerCase().replace(/ /g, '-'), tag);
    }
  }
  return [...tagMap.entries()].map(([slug, label]) => ({
    params: { tag: slug },
    props: { tag: slug, label },
  }));
}

const { tag, label } = Astro.props;
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => post.data.tags?.some(t => t.toLowerCase().replace(/ /g, '-') === tag))
  .sort((a, b) => getPostDate(b).valueOf() - getPostDate(a).valueOf());
---

<BlogLayout title={`Etiqueta: ${label}`}>
  <BlogSidebar slot="sidebar" />

  <h1 class="tag-title">Etiqueta: <span>{label}</span></h1>
  <p class="tag-count">{posts.length} entrada{posts.length !== 1 ? 's' : ''}</p>

  <div class="post-list">
    {posts.map(post => {
      const slug = post.data.slug ?? post.id;
      const url = `/pledin/${slug.replace(/^blog\//, '')}/`;
      const date = getPostDate(post);
      return (
        <PostCard
          url={url}
          title={post.data.title}
          date={date}
          readingTime={getReadingTime(post.body ?? '')}
          cover={post.data.cover}
          tags={post.data.tags ?? []}
          excerpt={post.data.excerpt ?? getExcerpt(post.body ?? '')}
        />
      );
    })}
  </div>
</BlogLayout>

<style>
  .tag-title {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }

  .tag-title span {
    color: var(--color-accent);
  }

  .tag-count {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
</style>
