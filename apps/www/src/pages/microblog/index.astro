---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@pledin/ui/layouts/BaseLayout.astro';
import MicropostCard from '@pledin/ui/components/MicropostCard.astro';

const allPosts = (await getCollection('microblog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const tagCount: Record<string, number> = {};
for (const post of allPosts) {
  for (const tag of post.data.tags ?? []) {
    tagCount[tag] = (tagCount[tag] ?? 0) + 1;
  }
}
const tags = Object.entries(tagCount).sort((a, b) => b[1] - a[1]);

const renderedPosts = await Promise.all(
  allPosts.map(async post => {
    const { Content } = await render(post);
    return { post, Content };
  })
);

const INITIAL = 10;
---

<BaseLayout title="Microblog">
  <div class="microblog-wrapper">
    <div class="microblog-header">
      <img src="/pledin/assets/logo_microblog.png" alt="Pledin" class="blog-banner" />

      <div class="tag-filter">
        {tags.map(([tag, count]) => (
          <a href={`/pledin/microblog/tags/${tag.toLowerCase().replace(/ /g, '-')}/`} class="tag">
            {tag} ({count})
          </a>
        ))}
      </div>
    </div>

    <div class="posts" id="posts">
      {renderedPosts.map(({ post, Content }, index) => {
        const date = post.data.date;
        const match = post.id.match(/^(\d{4})-(\d{2})-\d{2}-(.+)$/);
        const url = match
          ? `/pledin/microblog/${match[1]}/${match[2]}/${match[3]}/`
          : `/pledin/microblog/${post.id}/`;
        return (
          <MicropostCard
              url={url}
              title={post.data.title}
              date={post.data.date}
              tags={post.data.tags ?? []}
              dataIndex={index}
              hidden={index >= INITIAL}
            >
              <Content />
            </MicropostCard>
        );
      })}
    </div>

    {renderedPosts.length > INITIAL && (
      <div class="load-more-wrapper">
        <button id="load-more">Cargar más entradas</button>
      </div>
    )}
  </div>
</BaseLayout>

<script>
  const BATCH = 10;
  const posts = document.querySelectorAll('.micropost');
  const btn = document.getElementById('load-more');
  let shown = BATCH;

  btn?.addEventListener('click', () => {
    const next = shown + BATCH;
    for (let i = shown; i < next && i < posts.length; i++) {
      (posts[i] as HTMLElement).style.display = '';
    }
    shown = next;
    if (shown >= posts.length) btn.style.display = 'none';
  });
</script>

<style>
  .microblog-wrapper {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .microblog-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--color-border);
  }

  h1 {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    background: var(--color-bg-sidebar);
    color: var(--color-text-muted);
    padding: 0.2rem 0.6rem;
    border-radius: 1rem;
    text-decoration: none;
    transition: background 0.2s;
  }

  .tag:hover {
    background: var(--color-accent);
    color: white;
    text-decoration: none;
  }

  .posts {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .load-more-wrapper {
    display: flex;
    justify-content: center;
    margin-top: 2rem;
  }

  #load-more {
    background: var(--color-accent);
    color: white;
    border: none;
    padding: 0.75rem 2rem;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }

  #load-more:hover {
    background: var(--color-accent-high);
  }
  .load-more-wrapper {
  display: flex;
  justify-content: center;
  margin-top: 2.5rem;
  margin-bottom: 1rem;
}

#load-more {
  background: transparent;
  color: var(--color-accent);
  border: 2px solid var(--color-accent);
  padding: 0.75rem 3rem;
  border-radius: 2rem;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
  letter-spacing: 0.02em;
}

#load-more:hover {
  background: var(--color-accent);
  color: white;
}


.blog-banner {
  width: 100%;
  max-width: 500px;
  margin: 0 auto 2rem auto;
}

</style>