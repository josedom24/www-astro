---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@pledin/ui/layouts/BaseLayout.astro';
import MicropostCard from '@pledin/ui/components/MicropostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('microblog');
  return posts.map(post => {
    const match = post.id.match(/^(\d{4})-(\d{2})-\d{2}-(.+)$/);
    return {
      params: { year: match![1], month: match![2], slug: match![3] },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title}>
  <div class="microblog-wrapper">
    <a href="/pledin/microblog/" class="back">← Todos los posts</a>

    <MicropostCard
      url={Astro.url.pathname}
      title={post.data.title}
      date={post.data.date}
      tags={post.data.tags ?? []}
      detail={true}
    >
      <Content />
    </MicropostCard>
  </div>
</BaseLayout>

<style>
  .microblog-wrapper {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .back {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1.5rem;
  }

  .back:hover { color: var(--color-accent); }
</style>