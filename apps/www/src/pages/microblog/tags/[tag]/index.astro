---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@pledin/ui/layouts/BaseLayout.astro';
import MicropostCard from '@pledin/ui/components/MicropostCard.astro';

export async function getStaticPaths() {
  const posts = await getCollection('microblog');

  const tagMap = new Map<string, string>();
  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      tagMap.set(tag.toLowerCase().replace(/ /g, '-'), tag);
    }
  }

  return [...tagMap.entries()].map(([slug, label]) => ({
    params: { tag: slug },
    props: { tag: slug, label },
  }));
}

const { tag, label } = Astro.props;
const allPosts = await getCollection('microblog');
const posts = allPosts
  .filter(post => post.data.tags?.some(t => t.toLowerCase().replace(/ /g, '-') === tag))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const renderedPosts = await Promise.all(
  posts.map(async post => {
    const { Content } = await render(post);
    return { post, Content };
  })
);
---

<BaseLayout title={`Microblog: ${label}`}>
  <div class="microblog-wrapper">
    <div class="microblog-header">
      <a href="/pledin/microblog/" class="back">← Todos los posts</a>
      <h1>#{label}</h1>
      <p class="count">{posts.length} entrada{posts.length !== 1 ? 's' : ''}</p>
    </div>

    <div class="posts">
      {renderedPosts.map(({ post, Content }) => {
        const date = post.data.date;
        const match = post.id.match(/^(\d{4})-(\d{2})-\d{2}-(.+)$/);
        const url = match
          ? `/pledin/microblog/${match[1]}/${match[2]}/${match[3]}/`
          : `/pledin/microblog/${post.id}/`;
        return (
          <MicropostCard
              url={url}
              title={post.data.title}
              date={date}
              tags={post.data.tags ?? []}
            >
              <Content />
            </MicropostCard>
        );
      })}
    </div>
  </div>
</BaseLayout>

<style>
  .microblog-wrapper {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .microblog-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--color-border);
  }

  .back {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 0.75rem;
  }

  .back:hover { color: var(--color-accent); }

  h1 {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .count {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .posts {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
</style>