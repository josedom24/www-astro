---
import BaseLayout from '@pledin/ui/layouts/BaseLayout.astro';
import CourseCard from '@pledin/ui/components/CourseCard.astro';
import catalog from '../data/catalog.json';
---

<BaseLayout title="Catálogo de Cursos" description="Plataforma Educativa Informática. Cursos de José Domingo Muñoz.">
  <div class="catalog-hero">
    <div class="catalog-hero-inner">
      <h1>Plataforma Educativa Informática</h1>
      <p>Catálogo de cursos</p>
    </div>
  </div>
    <div class="catalog-intro">
    
    <p>
      Bienvenidos a PLEDIN, Plataforma Educativa Informática. Esta plataforma está mantenida por
      <a href="https://www.josedomingo.org">José Domingo Muñoz</a> y aquí podéis encontrar cursos
      relacionados con el mundo informático y la educación. Puedes acceder también al
      <a href="https://www.josedomingo.org/pledin/blog/">Blog PLEDIN</a>, donde encontrarás noticias
      y documentación relacionada con estos temas, y la
      <a href="https://fp.josedomingo.org">página módulos</a> donde estoy recopilando los contenidos
      de los distintos módulos que imparto en los ciclos formativos de informática del IES Gonzalo Nazareno.
    </p>
  </div>
  <div class="catalog-body">
    {catalog.map((section) => (
      <section class="catalog-section">
        <h2 class="section-heading">{section.title}</h2>
        <div class="course-grid">
          {section.courses.map((course) => (
            <CourseCard
              title={course.title}
              url={course.external !== 'none' ? course.url : 
                   course.url.startsWith('/pledin/') ? course.url : 
                   `/pledin/${course.url}`}
              year={course.year ?? undefined}
              external={course.external}
              ow={course.ow ?? false}
            />
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .catalog-hero {
    background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);
    color: white;
    padding: 1.5rem 0;
  }

  .catalog-hero-inner {
    max-width: calc(var(--sidebar-width) + var(--content-width) + 4rem);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .catalog-hero h1 {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.5rem;
    color: white;
  }

  .catalog-hero p {
    margin: 0;
    opacity: 0.85;
    color: white;
  }

  .catalog-hero a { color: #93c5fd; }

  .catalog-body {
    max-width: calc(var(--sidebar-width) + var(--content-width) + 4rem);
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .catalog-section { margin-bottom: 2.5rem; }

  .section-heading {
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text);
    border-bottom: 2px solid var(--color-border);
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
  }

  .course-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.75rem;
  }

  @media (max-width: 600px) {
    .course-grid { grid-template-columns: 1fr; }
    .catalog-hero { padding: 2rem 0; }
  }
    .catalog-intro {
    max-width: calc(var(--sidebar-width) + var(--content-width) + 4rem);
    margin: 0 auto;
    padding: 1.5rem 1.5rem 0;
  }

  .catalog-intro p {
    color: var(--color-text-muted);
    line-height: 1.7;
      
  }

  .catalog-intro h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  
</style>