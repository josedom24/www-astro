---
import { getCollection, render } from 'astro:content';
import DocLayout from '@pledin/ui/layouts/DocLayout.astro';

const navModules = import.meta.glob('../../data/nav/*.json', { eager: true });

export async function getStaticPaths() {
  const entries = await getCollection('cursos');
  return entries.map((entry) => {
    const slug = entry.id.replace(/\/index$/, '').replace(/^index$/, '') || undefined;
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const slugParts = entry.id.split('/');
const courseName = slugParts[0];

let nav = [];
const navPath = `../../data/nav/${courseName}.json`;
if (navModules[navPath]) {
  nav = (navModules[navPath] as { default: unknown }).default as typeof nav;
}

const slug = entry.id.replace(/\/index$/, '').replace(/^index$/, '');
const currentPath = `/pledin/cursos/${slug}/`;

const courseTitle = nav[0]?.title || courseName;
---

<DocLayout
  title={entry.data.title}
  courseTitle={courseTitle}
  nav={nav}
  currentPath={currentPath}
  description={entry.data.description}
>
  <Content />
</DocLayout>
