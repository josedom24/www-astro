---
import { getCollection, render } from 'astro:content';
import DocLayout from '@pledin/ui/layouts/DocLayout.astro';
import PostNav from '@pledin/ui/components/PostNav.astro';
import PostNav from '@pledin/ui/components/PostNav.astro';

const navModules = import.meta.glob('../../data/nav/*.json', { eager: true });

export async function getStaticPaths() {
  const entries = await getCollection('cursos');
  return entries.map((entry) => {
    const slug = entry.id.replace(/\/index$/, '').replace(/^index$/, '') || undefined;
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content , headings} = await render(entry);

const slugParts = entry.id.split('/');
const courseName = slugParts[0];

let nav = [];
const navPath = `../../data/nav/${courseName}.json`;
if (navModules[navPath]) {
  nav = (navModules[navPath] as { default: unknown }).default as typeof nav;
}

const slug = entry.id.replace(/\/index$/, '').replace(/^index$/, '');
const currentPath = `/pledin/cursos/${slug}/`;

const courseTitle = nav[0]?.title || courseName;


const pageTitle = entry.data.title ?? slug.split('/').pop() ?? courseName;
const flatLinks = nav.flatMap(section =>
  section.children 
    ? section.children.filter(c => c.url && !c.url.includes('#'))
    : (section.url && !section.url.includes('#') ? [section] : [])
);
const currentIndex = flatLinks.findIndex(item => item.url === currentPath);
const prev = flatLinks[currentIndex - 1];
const next = flatLinks[currentIndex + 1];

// Breadcrumb
const slugSegments = slug.split('/');
const breadcrumb = [
  { title: 'Cursos', url: '/pledin/' },
  { title: courseTitle, url: `/pledin/cursos/${slugSegments[0]}/` },
];
if (slugSegments.length > 1) {
  breadcrumb.push({ title: pageTitle, url: null });
}


//TOC
const showToc = entry.data.toc !== false;
---

<DocLayout
  title={pageTitle}
  courseTitle={courseTitle}
  nav={nav}
  currentPath={currentPath}
  headings={headings}
  breadcrumb={breadcrumb}
  headings={showToc ? headings : []}
>

  <h1>{pageTitle}</h1>
  <Content />
  <PostNav
    prevUrl={prev?.url}
    prevTitle={prev?.title}
    nextUrl={next?.url}
    nextTitle={next?.title}
  />
</DocLayout>

